/// word-domain icmp basic
let _ = %refly.equiv.struc_eq (%core.icmp.e  (42I8, 42I8), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ne (42I8, 43I8), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.e  (42I8, 43I8), ff);
let _ = %refly.equiv.struc_eq (%core.icmp.t  (42I8, 43I8), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.f  (42I8, 43I8), ff);

/// word-domain icmp signed vs unsigned
let _ = %refly.equiv.struc_eq (%core.icmp.sg  (1I8, 255I8), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ul  (1I8, 255I8), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sl  (255I8, 1I8), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ug  (255I8, 1I8), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sge (255I8, 255I8), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ule (255I8, 255I8), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sle (128I8, 127I8), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.uge (128I8, 127I8), tt);

/// non-power-of-two icmp on Idx 5
let _ = %refly.equiv.struc_eq (%core.icmp.e  (0_5, 0_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ne (0_5, 1_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ul (1_5, 4_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ug (4_5, 1_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sg (1_5, 4_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sl (4_5, 1_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sl (3_5, 4_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sg (4_5, 3_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sge (2_5, 3_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ule (2_5, 3_5), tt);

/// non-power-of-two icmp on Idx 9
let _ = %refly.equiv.struc_eq (%core.icmp.sg (4_9, 8_9), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sl (8_9, 4_9), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sl (5_9, 8_9), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sg (8_9, 5_9), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ul (4_9, 8_9), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ug (8_9, 4_9), tt);

/// non-power-of-two icmp on Idx 10
let _ = %refly.equiv.struc_eq (%core.icmp.sg (4_10, 5_10), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sl (5_10, 4_10), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sl (5_10, 9_10), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sg (9_10, 5_10), tt);

/// extrema unsigned
let _ = %refly.equiv.struc_eq (%core.extrema.umin (3I8, 250I8), 3I8);
let _ = %refly.equiv.struc_eq (%core.extrema.umax (3I8, 250I8), 250I8);
let _ = %refly.equiv.struc_eq (%core.extrema.umin (1_5, 4_5), 1_5);
let _ = %refly.equiv.struc_eq (%core.extrema.umax (1_5, 4_5), 4_5);
let _ = %refly.equiv.struc_eq (%core.extrema.umin (8_9, 5_9), 5_9);
let _ = %refly.equiv.struc_eq (%core.extrema.umax (8_9, 5_9), 8_9);

/// extrema signed on word domains
let _ = %refly.equiv.struc_eq (%core.extrema.smin (1I8, 255I8), 255I8);
let _ = %refly.equiv.struc_eq (%core.extrema.smax (1I8, 255I8), 1I8);
let _ = %refly.equiv.struc_eq (%core.extrema.smin (128I8, 127I8), 128I8);
let _ = %refly.equiv.struc_eq (%core.extrema.smax (128I8, 127I8), 127I8);
let _ = %refly.equiv.struc_eq (%core.extrema.smin (254I8, 255I8), 254I8);
let _ = %refly.equiv.struc_eq (%core.extrema.smax (254I8, 255I8), 255I8);

/// singleton Idx 1
let _ = %refly.equiv.struc_eq (%core.wrap.add %core.mode.us (0_1, 0_1), 0_1);
let _ = %refly.equiv.struc_eq (%core.wrap.sub %core.mode.us (0_1, 0_1), 0_1);
let _ = %refly.equiv.struc_eq (%core.wrap.mul %core.mode.us (0_1, 0_1), 0_1);
let _ = %refly.equiv.struc_eq (%core.extrema.umin (0_1, 0_1), 0_1);
let _ = %refly.equiv.struc_eq (%core.extrema.umax (0_1, 0_1), 0_1);
let _ = %refly.equiv.struc_eq (%core.icmp.e  (0_1, 0_1), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ne (0_1, 0_1), ff);
let _ = %refly.equiv.struc_eq (%core.icmp.t  (0_1, 0_1), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.f  (0_1, 0_1), ff);
//let _ = %refly.check_bot (%core.div.udiv (%mem.M 0, (0_1, 0_1)));
//let _ = %refly.check_bot (%core.div.urem (%mem.M 0, (0_1, 0_1)));
//let _ = %refly.check_bot (%core.div.sdiv (%mem.M 0, (0_1, 0_1)));
//let _ = %refly.check_bot (%core.div.srem (%mem.M 0, (0_1, 0_1)));

/// 64-bit signed overflow corner cases
let _ = %refly.equiv.struc_eq (%core.wrap.add %core.mode.us (9223372036854775807I64, 1I64), 9223372036854775808I64);
let _ = %refly.check_bot (%core.wrap.add %core.mode.nsw (9223372036854775807I64, 1I64));
let _ = %refly.equiv.struc_eq (%core.wrap.sub %core.mode.us (0I64, 1I64), 18446744073709551615I64);
let _ = %refly.check_bot (%core.wrap.sub %core.mode.nsw (9223372036854775808I64, 1I64));
let _ = %refly.equiv.struc_eq (%core.wrap.mul %core.mode.us (18446744073709551615I64, 18446744073709551615I64), 1I64);
let _ = %refly.check_bot (%core.wrap.mul %core.mode.nsw (9223372036854775808I64, 18446744073709551615I64));
//let _ = %refly.check_bot (%core.div.sdiv (%mem.M 0, (9223372036854775808I64, 18446744073709551615I64)));
//let _ = %refly.check_bot (%core.div.srem (%mem.M 0, (9223372036854775808I64, 18446744073709551615I64)));

/// non-power-of-two wrap arithmetic on Idx 5
let _ = %refly.equiv.struc_eq (%core.wrap.add %core.mode.us (4_5, 1_5), 0_5);
let _ = %refly.equiv.struc_eq (%core.wrap.add %core.mode.us (3_5, 4_5), 2_5);
let _ = %refly.equiv.struc_eq (%core.wrap.sub %core.mode.us (0_5, 1_5), 4_5);
let _ = %refly.equiv.struc_eq (%core.wrap.sub %core.mode.us (2_5, 4_5), 3_5);
let _ = %refly.equiv.struc_eq (%core.wrap.mul %core.mode.us (3_5, 4_5), 2_5);
let _ = %refly.equiv.struc_eq (%core.wrap.add %core.mode.nuw (1_5, 2_5), 3_5);
let _ = %refly.equiv.struc_eq (%core.wrap.sub %core.mode.nuw (4_5, 2_5), 2_5);
let _ = %refly.equiv.struc_eq (%core.wrap.mul %core.mode.nuw (2_5, 2_5), 4_5);
//let _ = %refly.equiv.struc_eq (%core.div.udiv (%mem.M 0, (4_5, 2_5)), (%mem.M 0, 2_5));
//let _ = %refly.equiv.struc_eq (%core.div.urem (%mem.M 0, (4_5, 3_5)), (%mem.M 0, 1_5));
let _ = %refly.check_bot (%core.wrap.add %core.mode.nuw (4_5, 1_5));
let _ = %refly.check_bot (%core.wrap.sub %core.mode.nuw (0_5, 1_5));
let _ = %refly.check_bot (%core.wrap.mul %core.mode.nuw (3_5, 4_5));
//let _ = %refly.check_bot (%core.wrap.add %core.mode.nsw (1_5, 1_5));
//let _ = %refly.check_bot (%core.wrap.sub %core.mode.nsw (1_5, 1_5));
//let _ = %refly.check_bot (%core.wrap.mul %core.mode.nsw (1_5, 1_5));

/// non-power-of-two arithmetic on Idx 10
let _ = %refly.equiv.struc_eq (%core.wrap.add %core.mode.us (9_10, 1_10), 0_10);
let _ = %refly.equiv.struc_eq (%core.wrap.sub %core.mode.us (0_10, 1_10), 9_10);
let _ = %refly.equiv.struc_eq (%core.wrap.mul %core.mode.us (7_10, 8_10), 6_10);
//let _ = %refly.equiv.struc_eq (%core.div.udiv (%mem.M 0, (9_10, 2_10)), (%mem.M 0, 4_10));
//let _ = %refly.equiv.struc_eq (%core.div.urem (%mem.M 0, (9_10, 2_10)), (%mem.M 0, 1_10));

/// extra edge checks for arbitrary icmp partitions
let _ = %refly.equiv.struc_eq (%core.icmp.e   (4_5, 4_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ne  (4_5, 4_5), ff);
let _ = %refly.equiv.struc_eq (%core.icmp.sle (3_5, 4_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sge (4_5, 3_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ule (3_5, 4_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.uge (4_5, 3_5), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.e   (8_9, 8_9), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ne  (8_9, 8_9), ff);
let _ = %refly.equiv.struc_eq (%core.icmp.sle (5_9, 8_9), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.sge (8_9, 5_9), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.ule (5_9, 8_9), tt);
let _ = %refly.equiv.struc_eq (%core.icmp.uge (8_9, 5_9), tt);

/// non-power-of-two unsupported signed/div/shift cases should bottom
let _ = %refly.check_bot (%core.wrap.shl %core.mode.us (1_5, 1_5));
let _ = %refly.check_bot (%core.shr.l (4_5, 1_5));
let _ = %refly.check_bot (%core.shr.a (4_5, 1_5));
//let _ = %refly.check_bot (%core.div.sdiv (%mem.M 0, (4_5, 1_5)));
//let _ = %refly.check_bot (%core.div.srem (%mem.M 0, (4_5, 1_5)));
